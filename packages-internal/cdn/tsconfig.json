{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "module": "ESNext",
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "moduleResolution": "Bundler",
    "allowJs": true,
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "types": ["vite/client", "node", "react"]
  },
  "include": ["src/**/*", "vite.config.js"]
}
