{
  "name": "@stoked-ui/file-explorer-v2",
  "version": "0.1.0",
  "description": "File Explorer V2 Component built on @mui/x-tree-view with rich customization support.",
  "author": "Brian Stoker",
  "main": "src/index.ts",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/stoked-ui/sui/issues"
  },
  "homepage": "https://stoked-ui.github.io/file-explorer-v2",
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "directory": "build"
  },
  "keywords": [
    "react",
    "react-component",
    "sui",
    "file explorer",
    "file-explorer",
    "mui",
    "stoked ui",
    "material ui",
    "material design"
  ],
  "scripts": {
    "typescript": "tsc -p tsconfig.json",
    "build": "pnpm build:modern && pnpm build:node && pnpm build:stable && pnpm build:types && pnpm build:copy-files",
    "build:modern": "node ../../scripts/build.mjs modern",
    "build:node": "node ../../scripts/build.mjs node",
    "build:stable": "node ../../scripts/build.mjs stable",
    "build:copy-files": "node ../../scripts/copyFiles.mjs",
    "build:types": "node ../../scripts/buildTypes.mjs",
    "prebuild": "rimraf build tsconfig.build.tsbuildinfo"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/stoked-ui/sui.git",
    "directory": "packages/sui-file-explorer-v2"
  },
  "dependencies": {
    "@mui/system": "^5.15.20",
    "@mui/x-tree-view": "^7.22.2",
    "@mui/x-tree-view-pro": "^7.22.2",
    "@react-spring/web": "^9.7.3",
    "@babel/runtime": "^7.24.7"
  },
  "peerDependencies": {
    "react": "18.3.1",
    "react-dom": "^17.0.0 || ^18.0.0",
    "@emotion/react": "^11.9.0",
    "@emotion/styled": "^11.8.1",
    "@mui/material": "^5.15.21",
    "@mui/icons-material": "^5.15.21"
  },
  "engines": {
    "node": ">=14.0.0"
  }
}
