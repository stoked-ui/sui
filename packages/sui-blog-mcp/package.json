{
  "name": "@stoked-ui/blog-mcp",
  "author": "Brian Stoker",
  "private": false,
  "version": "1.0.0",
  "description": "MCP (Model Context Protocol) server that exposes blog CRUD operations as tools, enabling AI agents to author and manage blog posts programmatically",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "blog",
    "cms",
    "ai",
    "claude",
    "rest-api"
  ],
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "bin": {
    "sui-blog-mcp": "dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/stoked-ui/sui",
    "directory": "packages/sui-blog-mcp"
  },
  "publishConfig": {
    "access": "public",
    "directory": "dist"
  },
  "scripts": {
    "prebuild": "rimraf dist tsconfig.tsbuildinfo",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "type-check": "tsc --noEmit",
    "typescript": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^22.12.0",
    "@typescript-eslint/eslint-plugin": "^6.19.1",
    "@typescript-eslint/parser": "^6.19.1",
    "jest": "^29.7.0",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": [
        "ts-jest",
        {
          "tsconfig": {
            "allowJs": true
          },
          "diagnostics": false
        }
      ]
    },
    "collectCoverageFrom": [
      "**/*.ts",
      "!**/__tests__/**"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
