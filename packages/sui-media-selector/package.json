{
  "name": "@stoked-ui/media-selector",
  "author": "Brian Stoker",
  "private": false,
  "version": "0.1.3",
  "description": "Media selector component for the Stoked UI ecosystem",
  "license": "MIT",
  "main": "./node/index.js",
  "module": "./esm/index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./esm/index.js",
      "require": "./node/index.js",
      "default": "./esm/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "build"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/stoked-ui/sui",
    "directory": "packages/sui-media-selector"
  },
  "publishConfig": {
    "access": "public",
    "directory": "build"
  },
  "sideEffects": false,
  "scripts": {
    "build": "pnpm build:all",
    "typescript": "tsc -p tsconfig.json",
    "copyToDocs": "cp -r ./dist/assets ../../docs/",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "build:all": "pnpm build:modern && pnpm build:node && pnpm build:stable && pnpm build:types && pnpm build:copy-files",
    "build:modern": "node ../../scripts/build.mjs modern",
    "build:node": "node ../../scripts/build.mjs node",
    "build:stable": "node ../../scripts/build.mjs stable",
    "build:copy-files": "node ../../scripts/copyFiles.mjs",
    "build:types": "node ../../scripts/buildTypes.mjs",
    "prebuild": "rimraf build tsconfig.build.tsbuildinfo",
    "release": "pnpm build && pnpm publish"
  },
  "peerDependencies": {
    "@stoked-ui/common": "workspace:^",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.9",
    "@babel/plugin-transform-runtime": "^7.23.9",
    "@babel/plugin-transform-typescript": "^7.26.8",
    "@babel/preset-env": "^7.26.9",
    "@babel/preset-react": "^7.23.3",
    "@babel/preset-typescript": "^7.26.0",
    "@babel/runtime": "^7.24.7",
    "@stoked-ui/common": "workspace:^",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.2.16",
    "@types/wicg-file-system-access": "^2023.10.5",
    "eslint": "^8.57.0",
    "typescript": "5.4.5"
  },
  "dependencies": {
    "formdata-node": "^6.0.3",
    "jszip": "^3.10.1"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "keywords": [
    "react",
    "react-component",
    "sui",
    "mui",
    "stoked ui",
    "media",
    "selector",
    "file picker"
  ]
}
