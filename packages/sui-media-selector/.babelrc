{
  "presets": [
    ["@babel/preset-env", {
      "targets": {
        "browsers": [
          "last 2 versions",
          "not dead",
          "not ie <= 11"
        ],
        "node": "14"
      },
      "modules": false,
      "loose": true
    }],
    "@babel/preset-typescript",
    ["@babel/preset-react", {
      "runtime": "automatic"
    }]
  ],
  "plugins": [
    "@babel/plugin-transform-runtime",
    ["@babel/plugin-transform-typescript", {
      "isTSX": true,
      "allExtensions": true
    }]
  ],
  "env": {
    "node": {
      "presets": [
        ["@babel/preset-env", {
          "targets": {
            "node": "14"
          },
          "modules": "commonjs"
        }]
      ]
    }
  }
} 
