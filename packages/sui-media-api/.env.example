# ─────────────────────────────────────────────────────────────────────────────
# Server Configuration
# ─────────────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
API_PATH_PREFIX=/v1

# ─────────────────────────────────────────────────────────────────────────────
# Database Configuration
# ─────────────────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/stoked-media
MONGODB_RETRY_ATTEMPTS=3
MONGODB_RETRY_DELAY=1000

# ─────────────────────────────────────────────────────────────────────────────
# AWS Configuration
# ─────────────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_S3_BUCKET=stoked-media-uploads
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_S3_ENDPOINT=
AWS_S3_FORCE_PATH_STYLE=false

# ─────────────────────────────────────────────────────────────────────────────
# Media Processing Configuration
# ─────────────────────────────────────────────────────────────────────────────
FFMPEG_PATH=/usr/bin/ffmpeg
FFPROBE_PATH=/usr/bin/ffprobe
MEDIA_PROCESSING_TIMEOUT=300000
THUMBNAIL_SIZES=320,640,1280
THUMBNAIL_QUALITY=80
MAX_FILE_SIZE=1073741824
ALLOWED_MEDIA_TYPES=video/mp4,video/webm,image/jpeg,image/png,image/webp

# ─────────────────────────────────────────────────────────────────────────────
# Logging Configuration
# ─────────────────────────────────────────────────────────────────────────────
LOG_LEVEL=log
LOG_REQUESTS=true
LOG_DATABASE_QUERIES=false
STRUCTURED_LOGS=false

# ─────────────────────────────────────────────────────────────────────────────
# Authentication Configuration
# ─────────────────────────────────────────────────────────────────────────────
API_KEY=your-secure-api-key

# Secret used to sign and verify JWTs — must be a long random string in production
# Generate with: openssl rand -hex 32
JWT_SECRET=your-jwt-secret-key
JWT_EXPIRES_IN=7d

# Comma-separated list of email domains that automatically receive the
# "author" role on registration.
AUTH_AUTO_DOMAINS=stokedconsulting.com,stoked-ui.com,brianstoker.com

# If set, running `pnpm db:init` will create an admin user with these credentials.
AUTH_ADMIN_EMAIL=admin@yourdomain.com
AUTH_ADMIN_PASSWORD=change-me-secure-admin-password
AUTH_ADMIN_NAME=Admin

# ─────────────────────────────────────────────────────────────────────────────
# Cache Configuration
# ─────────────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
CACHE_TTL=3600
ENABLE_CACHE=true

# ─────────────────────────────────────────────────────────────────────────────
# Performance Configuration
# ─────────────────────────────────────────────────────────────────────────────
REQUEST_TIMEOUT=30000
MAX_CONCURRENT_UPLOADS=10
ENABLE_COMPRESSION=true
KEEPALIVE_TIMEOUT=65000

# ─────────────────────────────────────────────────────────────────────────────
# Blog — MCP server authentication
# ─────────────────────────────────────────────────────────────────────────────
# Shared secret used by the blog-mcp server to authenticate against this API.
# Generate with: openssl rand -hex 32
BLOG_API_TOKEN=change-me-to-a-secure-random-token

# ─────────────────────────────────────────────────────────────────────────────
# Nostr Integration (optional — leave blank to disable)
# ─────────────────────────────────────────────────────────────────────────────
# Comma-separated list of Nostr WebSocket relay URLs to poll
NOSTR_RELAYS=wss://relay.damus.io,wss://nos.lol

# Comma-separated list of npub public keys whose NIP-23 posts to import
NOSTR_NPUBS=

# How often (in minutes) to poll the Nostr relays (default: 15)
NOSTR_POLL_INTERVAL=15

# Comma-separated list of target sites for Nostr-imported posts
NOSTR_TARGET_SITES=stoked-ui.com,brian.stoker.work

# ─────────────────────────────────────────────────────────────────────────────
# CORS Configuration
# ─────────────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000
CORS_METHODS=GET,POST,PUT,DELETE,PATCH

# Comma-separated list of origins allowed for CORS (used by ALLOWED_ORIGINS in Lambda)
ALLOWED_ORIGINS=http://localhost:3000,https://stoked-ui.com,https://www.stoked-ui.com

# ─────────────────────────────────────────────────────────────────────────────
# SST Configuration (for AWS deployment)
# ─────────────────────────────────────────────────────────────────────────────
SST_STAGE=dev

# ─────────────────────────────────────────────────────────────────────────────
# Optional: Error Tracking (Sentry)
# ─────────────────────────────────────────────────────────────────────────────
SENTRY_DSN=
