{
  "extends": "../../tsconfig.x.json",
  "compilerOptions": {
    "target": "ES2015",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": [
      "@stoked-ui/internal-test-utils/initMatchers",
      "@mui/material/themeCssVarsAugmentation",
      "chai-dom",
      "mocha",
      "node",
      "wicg-file-system-access"
    ],
    "importHelpers": true,
    "jsx": "react",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "sourceMap": true,
    "baseUrl": "./",
    "strict": false,
    "noImplicitAny": false,
    "allowSyntheticDefaultImports": true,
    "typeRoots": [
      "./node_modules/@types",
      "./src/types"
    ]
  },
  "include": [
    "src/**/*",
    "src/custom.d.ts"
  ],
  "exclude": ["**/*.test.tsx"]
}
