{
  "extends": "../tsconfig.json",
  "include": [
    "next-env.d.ts",
    "types",
    "src",
    "pages",
    "data",
    "next.config.mjs"
  ],
  "exclude": [
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.ts",
    "src/**/*.spec.tsx"
  ],
  "compilerOptions": {
    "allowJs": true,
    "isolatedModules": true,
    /* files are emitted by babel */
    "noEmit": true,
    "noUnusedLocals": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "types": [
      "react"
    ],
    "incremental": true,
    "target": "ES2019",
    "jsx": "preserve"
  }
}
