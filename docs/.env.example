# ─────────────────────────────────────────────────────────────────────────────
# Stoked UI docs app — environment reference
# Copy to .env.local (Next.js) and fill in real values. Everything here has a
# safe default or degrades gracefully when unset, EXCEPT where marked REQUIRED.
# The app runs on http://localhost:5199 in development (pnpm docs:dev).
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (REQUIRED for audit bot lead capture, blog, products, licenses) ──
# All business-domain data lives in MongoDB.
MONGODB_URI=mongodb://localhost:27017/stoked-media

# ── Audit bot — LLM inference ────────────────────────────────────────────────
# OpenAI-compatible endpoint. Default assumes LM Studio on the same machine.
# ⚠ PRODUCTION: localhost will NOT work on a deployed host. Point this at the
#   inference box (e.g. https://hq.stokd.cloud/v1 via tailscale/funnel) or any
#   OpenAI-compatible provider. If unreachable, /api/audit/turn returns 500 and
#   the chat UI shows the email-fallback path — the bot is degraded, not down.
AUDIT_BOT_BASE_URL=http://localhost:1234/v1
# Any non-empty string for LM Studio; a real key for hosted providers.
AUDIT_BOT_API_KEY=lm-studio
# Must exactly match a model id served at ${AUDIT_BOT_BASE_URL}/models.
AUDIT_BOT_MODEL=qwen3-vl-32b-instruct

# ── Audit bot — lead notifications (Telegram) ────────────────────────────────
# Silent no-op when unset. Brian gets a message per completed audit/lead.
TELEGRAM_BOT_TOKEN=
# Falls back to TELEGRAM_CHAT_ID if the support-specific id is unset.
TELEGRAM_SUPPORT_CHAT_ID=
# Optional forum-thread routing (first match wins):
# TELEGRAM_AUDIT_THREAD_ID > TELEGRAM_SUPPORT_THREAD_ID > TELEGRAM_THREAD_ID
TELEGRAM_AUDIT_THREAD_ID=

# ── Audit bot — report email (SES) ───────────────────────────────────────────
# When a visitor leaves an email, their audit report is sent via SES from
# /api/audit/save-lead. Requires SES-verified sender + AWS credentials in the
# runtime (AWS_PROFILE=stokd-cloud locally; the SST role in prod).
AWS_REGION=us-east-1
SES_FROM_EMAIL=noreply@stokd.cloud
# Optional: BCC every outgoing report (so the follow-up thread starts in inbox).
AUDIT_REPORT_BCC_EMAIL=

# ── GitHub (optional) ────────────────────────────────────────────────────────
# Used by /api/github/* (contributions, events, PR details) and by
# /api/install/<product>.sh (install.stokd.cloud). Without it:
#   - /api/github/* runs unauthenticated at GitHub's 60 req/hr per-IP limit
#   - install scripts only work for PUBLIC product repos
# With it: 5,000 req/hr, and install scripts can be pulled from private repos.
# Fine-grained PAT with read-only "Contents" access to the product repos is enough.
GITHUB_TOKEN=

# ── Consulting funnel ────────────────────────────────────────────────────────
# "Book a 30-min call" button in the audit bot + report emails. Hidden if unset.
NEXT_PUBLIC_CALENDLY_URL=
